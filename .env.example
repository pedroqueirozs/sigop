# Banco de dados — Neon PostgreSQL
# Obtenha as URLs em: https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?connect_timeout=15"

# Sessão — gere com: openssl rand -base64 32
SESSION_SECRET="sua_chave_secreta_aqui"

# Vercel Blob — obtenha em: vercel.com/dashboard → Storage → Blob
# Necessário para upload de fotos
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
